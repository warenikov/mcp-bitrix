{
    "name": "warenikov/mcp-bitrix",
    "description": "MCP server for Bitrix CMS — manage iblocks, highload, users, ORM via Claude",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Warenikov\\McpBitrix\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Warenikov\\McpBitrix\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests/Unit"
    },
    "bin": ["bin/server"]
}
